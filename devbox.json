{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
  "packages": [
    "opentofu@latest",
    "kubectl@latest",
    "talosctl@latest",
    "kubernetes-helm@latest",
    "cilium-cli@latest",
    "k9s@latest",
    "ansible@latest",
    "sops@latest",
    "age@latest",
    "jq@latest",
    "python3@latest",
    "nmap@latest",
    "curl@latest",
    "cloudflared@latest",
    "yq-go@latest",
    "bind@latest",
    "netcat-gnu@latest",
    "awscli2@latest",
    "openssl@latest",
    "tea@latest",
    "keepassxc@latest"
  ],
  "env": {
    "TALOSCONFIG": "$PWD/tofu/talosconfig",
    "KUBECONFIG": "$PWD/tofu/kubeconfig"
  },
  "shell": {
    "init_hook": [
      "test -n \"$DEVBOX_QUIET\" || echo \"homelab toolchain ready — $(tofu version | head -1)\""
    ],
    "scripts": {
      "tf-validate": [
        "tofu -chdir=tofu init -backend=false -input=false",
        "tofu -chdir=tofu validate"
      ],
      "tf-plan": [
        "tofu -chdir=tofu init -input=false",
        "tofu -chdir=tofu plan"
      ],
      "k9s": [
        "KUBECONFIG=$PWD/tofu/kubeconfig k9s"
      ],
      "nodes": [
        "KUBECONFIG=$PWD/tofu/kubeconfig kubectl get nodes -o wide"
      ],
      "cordon": [
        "kubectl cordon \"$@\""
      ],
      "uncordon": [
        "kubectl uncordon \"$@\""
      ],
      "opnsense": [
        "echo 'Run an OPNsense playbook with creds+httpx interpreter:' && echo '  bash scripts/opnsense-playbook.sh ansible/opnsense-<play>.yml'"
      ],
      "kubeconfig": [
        "tofu -chdir=tofu output -raw kubeconfig > tofu/kubeconfig && chmod 600 tofu/kubeconfig && echo wrote tofu/kubeconfig"
      ],
      "talos-usb": [
        "bash scripts/talos-usb.sh"
      ],
      "keepass-init": [
        "bash scripts/keepass-init.sh"
      ],
      "flash-irrigation": [
        "export PLATFORMIO_CORE_DIR=$PWD/esphome/.platformio",
        "test -x esphome/.flash-venv/bin/esphome || python3 -m venv esphome/.flash-venv",
        "esphome/.flash-venv/bin/pip install -q --upgrade esphome",
        "esphome/.flash-venv/bin/esphome run esphome/config/office-plants-irrigation.yaml --device 192.168.2.245 --no-logs",
        "chown -R $(stat -c %u:%g devbox.json) esphome/.flash-venv esphome/.platformio esphome/config/.esphome 2>/dev/null || true"
      ],
      "irrigation-logs": [
        "esphome/.flash-venv/bin/esphome logs esphome/config/office-plants-irrigation.yaml --device 192.168.2.245"
      ]
    }
  }
}
