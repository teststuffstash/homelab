{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "title": "Agents — running & stalls",
  "uid": "agent-running",
  "tags": ["agents", "fu-057"],
  "schemaVersion": 39,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Workers running",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "text", "value": null } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": [ "lastNotNull" ] }, "colorMode": "value", "graphMode": "area" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(kube_pod_status_phase{phase=\"Running\", pod=~\"agent-.*\"}) or vector(0)" } ]
    },
    {
      "id": 2, "type": "stat", "title": "Reviewers running",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "text", "value": null } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": [ "lastNotNull" ] }, "colorMode": "value", "graphMode": "area" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(kube_pod_status_phase{phase=\"Running\", pod=~\"reviewer-.*\"}) or vector(0)" } ]
    },
    {
      "id": 3, "type": "stat", "title": "Coordinators running",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "text", "value": null } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": [ "lastNotNull" ] }, "colorMode": "value", "graphMode": "area" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(kube_pod_status_phase{phase=\"Running\", pod=~\"coordinator-.*\"}) or vector(0)" } ]
    },
    {
      "id": 4, "type": "stat", "title": "Green PRs waiting for review",
      "description": "Open, non-draft PRs whose CI is green but which have no approval yet (review_required). This is the head of the 2.5h-stall: a PR that is ready to merge but nothing is acting on it. Pair with 'Reviewers running' — waiting>0 while reviewers=0 for minutes IS the stall (measured 2026-07-09, docs/agents/observability-and-retro.md §A′). Needs github_pull_request_open from github-exporter.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 1 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": [ "lastNotNull" ] }, "colorMode": "background", "graphMode": "none" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "count(github_pull_request_open{review_decision=\"review_required\", ci_state=~\"success|none\", draft=\"false\"}) or vector(0)" } ]
    },
    {
      "id": 5, "type": "stat", "title": "Oldest waiting PR (age)",
      "description": "Time since the oldest green-unapproved PR was last updated. Sustained growth here = the review reflex is not progressing an armed PR (the 2.5h silent stall).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 900 }, { "color": "red", "value": 3600 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": [ "lastNotNull" ] }, "colorMode": "value", "graphMode": "none" },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "time() - min(github_pull_request_updated_timestamp{review_decision=\"review_required\", ci_state=~\"success|none\", draft=\"false\"})" } ]
    },
    {
      "id": 6, "type": "timeseries", "title": "Agent pods by role (running)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "min": 0, "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 20, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": [ "lastNotNull", "max" ] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(kube_pod_status_phase{phase=\"Running\", pod=~\"agent-.*\"}) or vector(0)", "legendFormat": "worker" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(kube_pod_status_phase{phase=\"Running\", pod=~\"reviewer-.*\"}) or vector(0)", "legendFormat": "reviewer" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(kube_pod_status_phase{phase=\"Running\", pod=~\"coordinator-.*\"}) or vector(0)", "legendFormat": "coordinator" }
      ]
    },
    {
      "id": 7, "type": "timeseries", "title": "Stall detector — green-unapproved PRs vs reviewers running",
      "description": "When 'green PRs waiting' stays above 0 while 'reviewers running' sits at 0, the loop is stalled on an invisible reflex gap — the single biggest measured time sink. This panel makes that 2.5h silence a glance.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "min": 0, "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": [ "lastNotNull", "max" ] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "count(github_pull_request_open{review_decision=\"review_required\", ci_state=~\"success|none\", draft=\"false\"}) or vector(0)", "legendFormat": "green PRs waiting" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(kube_pod_status_phase{phase=\"Running\", pod=~\"reviewer-.*\"}) or vector(0)", "legendFormat": "reviewers running" }
      ]
    },
    {
      "id": 8, "type": "table", "title": "Active agent pods",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "options": { "showHeader": true },
      "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "kube_pod_status_phase{phase=\"Running\", pod=~\"agent-.*|reviewer-.*|coordinator-.*\"} == 1", "format": "table", "instant": true } ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "Value": true, "__name__": true, "container": true, "endpoint": true, "instance": true, "job": true, "service": true, "uid": true, "phase": true }, "renameByName": { "namespace": "namespace", "pod": "pod" } } }
      ]
    }
  ]
}
