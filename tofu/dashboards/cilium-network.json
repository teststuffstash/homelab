  "description": "Comprehensive Cilium network monitoring dashboard for Kubernetes clusters. Features instance filtering by Cilium instances (IP:port), endpoint state monitoring, BPF map usage, API performance metrics, and node connectivity status.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Shows how long it takes for Cilium agents to start up and become ready. **Overall Bootstrap** is total startup time, **Daemon Init** is core daemon initialization, and **K8s Init** is Kubernetes integration setup. Green = fast (<5s), Yellow = slow (5-10s), Red = very slow (>10s). High values may indicate resource constraints or network issues.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "orange",
                "value": 5
              },
              {
                "color": "dark-red",
                "value": 10
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 24,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "percentChangeColorMode": "standard",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "auto",
        "wideLayout": true
      },
      "pluginVersion": "12.1.1",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "cilium_agent_bootstrap_seconds{scope=\"overall\", instance=~\".*\"}",
          "legendFormat": "Overall Bootstrap - {{instance}}",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "cilium_agent_bootstrap_seconds{scope=\"daemonInit\", instance=~\".*\"}",
          "legendFormat": "Daemon Init - {{instance}}",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "cilium_agent_bootstrap_seconds{scope=\"k8sInit\", instance=~\".*\"}",
          "legendFormat": "K8s Init - {{instance}}",
          "refId": "C"
        }
      ],
      "title": "Cilium Agent Bootstrap Time",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Shows the total count of errors and warnings from Cilium components across all worker nodes. **ERROR** level indicates serious issues that may affect network functionality, **WARN** level indicates potential problems, **INFO** level shows normal operational messages. Zero counts are ideal. Spikes in errors may indicate network policy conflicts, resource exhaustion, or configuration issues. Monitor for sustained error rates or unusual warning patterns.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
