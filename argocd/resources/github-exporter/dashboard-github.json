        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "max by (repo, workflow) (github_workflow_run_duration_seconds{branch=~\"master|main\"})",
          "legendFormat": "{{repo}}/{{workflow}} [{{runner}}]"
