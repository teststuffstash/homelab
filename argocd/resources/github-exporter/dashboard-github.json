    {
      "id": 6,
      "type": "stat",
      "title": "Last successful poll",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
