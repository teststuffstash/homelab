/.idea/

# Claude Code: personal/local settings (permissions allowlist) stay out of git;
# shared project skills under .claude/skills/ ARE committed.
/.claude/settings.local.json

# upload server inbox — move files out to commit them
/uploads/

# Devbox per-project env (regenerated from devbox.json/devbox.lock; not committed).
# devbox.lock IS committed — it's the deterministic version pin.
/.venv/
/.devbox/

# ESPHome flash toolchain (created by `devbox run flash-irrigation`): a pip venv +
# PlatformIO core/toolchain cache. Large, machine-local, regenerated on demand.
/esphome/.flash-venv/
/esphome/.platformio/
/.obsidian/

# Generated live from the GitHub API (click-only app installs) — not a git artifact.
/docs/github-apps.md
